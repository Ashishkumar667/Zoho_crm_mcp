# Server mode
MCP_TRANSPORT=http
PORT=3000

# Zoho region
ZOHO_DATA_CENTER=com
ZOHO_REDIRECT_URI=http://localhost:8080/callback

# Preferred refresh-token flow
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token

# Optional direct access tokens
# If you set these, the server uses them directly and skips token refresh flow.
ZOHO_ACCESS_TOKEN=
ZOHO_CRM_ACCESS_TOKEN=
ZOHO_MAIL_ACCESS_TOKEN=

# Optional custom base URLs
# Usually you do not need to change these.
ZOHO_ACCOUNTS_BASE_URL=
ZOHO_CRM_BASE_URL=
ZOHO_MAIL_BASE_URL=
